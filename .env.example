KOFIC_BOX_OFFICE_SERVICE_KEY=your-kofic-service-key
# KOFIC_BOX_OFFICE_SERVICE_KEY_ENCODED=your-kofic-url-encoded-service-key

ARKO_EVENT_SERVICE_KEY=your-arko-service-key
# ARKO_EVENT_SERVICE_KEY_ENCODED=your-arko-url-encoded-service-key

MCST_PERFORMANCE_SERVICE_KEY=your-mcst-performance-service-key
# MCST_PERFORMANCE_SERVICE_KEY_ENCODED=your-mcst-performance-url-encoded-service-key

KOFIC_BOX_OFFICE_API_BASE=https://api.kcisa.kr/openapi/service/rest/meta5
KOFIC_BOX_OFFICE_TIMEOUT_SECONDS=15
ARKO_EVENT_API_BASE=https://api.kcisa.kr/openapi/service/rest/meta
ARKO_EVENT_TIMEOUT_SECONDS=15
MCST_PERFORMANCE_API_BASE=https://api.kcisa.kr/openapi/CNV_060
MCST_PERFORMANCE_TIMEOUT_SECONDS=15

KOFIC_BOX_OFFICE_MCP_HOST=127.0.0.1
KOFIC_BOX_OFFICE_MCP_PORT=8000
KOFIC_BOX_OFFICE_MCP_PATH=/mcp

# Example values when exposing outside loopback.
# KOFIC_BOX_OFFICE_MCP_ALLOWED_HOSTS=127.0.0.1:*,localhost:*
# KOFIC_BOX_OFFICE_MCP_ALLOWED_ORIGINS=http://127.0.0.1:*,http://localhost:*
